// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tenant (Company)
model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  products  Product[]
  customers Customer[]
  invoices  Invoice[]
  accounts  Account[]
  ledger    JournalEntry[]
  employees Employee[]
  expenses  Expense[]
  campaigns Campaign[]
  leads     Lead[]
  assets    Asset[]
  payroll   PayrollRecord[]
  timeEntries TimeEntry[]
  maintenanceRecords MaintenanceRecord[]
}

// User (Admin, Accountant, Staff)
model User {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  email     String
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
}

// Product (Inventory)
model Product {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  name        String
  sku         String
  description String?
  imageUrl    String?
  category    String
  unit        String        // e.g. "piece", "kg", "hr"

  price       Float
  costPrice   Float?
  taxRate     Float   @default(0)  // percentage e.g. 18.0

  stock       Int     @default(0)
  lowStockAlert Int   @default(5)

  isActive    Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  invoiceItems InvoiceItem[]

  @@unique([sku, tenantId])
}

// Customer (Client)
model Customer {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  
  name      String
  email     String?
  phone     String?
  company   String?
  website   String?
  
  // Tax & Legal
  taxNumber          String?   // GST/VAT/EIN
  registrationNumber String?
  
  // Addresses (Stored as JSON for flexibility)
  billingAddress  Json?
  shippingAddress Json?
  
  // Financial Control
  currency      String        @default("USD")
  paymentTerms  PaymentTerms  @default(NET_30)
  creditLimit   Float         @default(0)
  currentBalance Float        @default(0)
  
  // Metrics & Behavior
  paymentBehaviorScore    Int     @default(100)
  latePaymentInterestRate Float   @default(0)
  status                  CustomerStatus @default(ACTIVE)
  
  tags      String[]
  notes     String?
  
  contacts  ContactPerson[]
  invoices  Invoice[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([email, tenantId])
}

model ContactPerson {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  name        String
  email       String
  phone       String
  role        String?
  isPrimary   Boolean  @default(false)
}

// Invoice (Sale)
model Invoice {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  
  invoiceNo   String
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id])
  
  date        DateTime      @default(now())
  dueDate     DateTime
  
  status      InvoiceStatus @default(DRAFT)
  
  currency    String        @default("USD")
  subtotal    Float
  taxTotal    Float         @default(0)
  discount    Float         @default(0)
  total       Float
  
  notes       String?
  items       InvoiceItem[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([invoiceNo, tenantId])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  
  description String
  quantity    Float
  rate        Float
  total       Float
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  ON_HOLD
  BLOCKED
}

enum PaymentTerms {
  NET_7
  NET_15
  NET_30
  DUE_ON_RECEIPT
  CUSTOM
}

enum Role {
  ADMIN
  ACCOUNTANT
  STAFF
}

// --- Accounting Module ---

model Account {
  id          String      @id @default(uuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  
  name        String
  code        String      // e.g. "1001", "4000"
  type        AccountType
  description String?
  
  balance     Float       @default(0)
  isActive    Boolean     @default(true)
  
  journalItems JournalItem[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([code, tenantId])
}

model JournalEntry {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  
  date        DateTime      @default(now())
  reference   String?       // e.g. Invoice #123, Payment #456
  description String
  status      JournalStatus @default(DRAFT)
  
  items       JournalItem[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model JournalItem {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  
  debit          Float        @default(0)
  credit         Float        @default(0)
  
  description    String?
}

// --- HR & Operations Module ---

model Employee {
  id          String         @id @default(uuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  
  firstName   String
  lastName    String
  email       String
  phone       String?
  jobTitle    String
  department  String
  status      EmployeeStatus @default(ACTIVE)
  hireDate    DateTime       @default(now())
  
  attendance  Attendance[]
  leaves      LeaveRequest[]
  expenses    Expense[]
  payroll     PayrollRecord[]
  timeEntries TimeEntry[]
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([email, tenantId])
}

model Attendance {
  id          String           @id @default(uuid())
  employeeId  String
  employee    Employee         @relation(fields: [employeeId], references: [id])
  
  date        DateTime         @default(now())
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttendanceStatus @default(PRESENT)
  
  @@unique([employeeId, date])
}

model LeaveRequest {
  id          String      @id @default(uuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id])
  
  startDate   DateTime
  endDate     DateTime
  type        String      // e.g. "SICK", "VACATION"
  reason      String?
  status      LeaveStatus @default(PENDING)
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Expense {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  
  employeeId  String?
  employee    Employee?     @relation(fields: [employeeId], references: [id])
  
  date        DateTime      @default(now())
  category    String        // e.g. "TRAVEL", "SUPPLIES"
  amount      Float
  currency    String        @default("USD")
  description String
  status      ExpenseStatus @default(PENDING)
  receiptUrl  String?
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ON_LEAVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  ON_LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalStatus {
  DRAFT
  POSTED
  CANCELLED
}

// --- Marketing Module ---

model Campaign {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  name        String
  type        String   // e.g. "EMAIL", "SOCIAL", "AD"
  status      String   @default("DRAFT") // DRAFT, ACTIVE, COMPLETED
  startDate   DateTime?
  endDate     DateTime?
  budget      Float    @default(0)
  spend       Float    @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  firstName   String
  lastName    String
  email       String
  phone       String?
  source      String?  // e.g. "WEB", "REFERRAL"
  status      String   @default("NEW") // NEW, CONTACTED, QUALIFIED, LOST
  score       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Payroll Module ---

model PayrollRecord {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  
  period      String   // e.g. "2024-02"
  amount      Float
  status      String   @default("PENDING") // PENDING, PROCESSED, PAID
  paymentDate DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Assets Module ---

model Asset {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  name        String
  category    String   // e.g. "HARDWARE", "SOFTWARE", "VEHICLE"
  status      String   @default("ACTIVE") // ACTIVE, UNDER_MAINTENANCE, DISPOSED
  purchaseDate DateTime
  purchaseCost Float?
  currentValue  Float
  
  location      String?
  serialNumber  String?
  department    String?
  assignedTo    String?
  notes         String?
  depreciationMethod String?
  riskFactor    String?
  utilization   Float? @default(0)
  
  lastMaintenanceDate DateTime?
  maintenanceCost     Float?
  maintenanceNotes    String?
  nextServiceDate     DateTime?
  
  maintenanceHistory  MaintenanceRecord[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MaintenanceRecord {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  date        DateTime @default(now())
  type        String   // e.g. "Routine", "Repair", "Upgrade"
  description String
  cost        Float    @default(0)
  performer   String?
  status      String   @default("COMPLETED") // COMPLETED, SCHEDULED, CANCELLED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Time Module ---

model TimeEntry {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  
  date        DateTime @default(now())
  hours       Float
  description String?
  project     String?
  task        String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
